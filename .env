# Database Configuration (XAMPP default)
DATABASE_URL="mysql://root:@localhost:3306/digital_health_system"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_complex_123456789
JWT_EXPIRES_IN=8h

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here_123456789

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000