generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClinicalNote {
  id   String @id @default(cuid())
  note String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId String      @unique

  patient   User   @relation("PatientNotes", fields: [patientId], references: [id])
  patientId String

  provider   User    @relation("ProviderNotes", fields: [providerId], references: [id])
  providerId String
  User       User?   @relation(fields: [userId], references: [id])
  userId     String?
}

model User {
  id                     String         @id @default(cuid())
  email                  String         @unique
  password               String
  firstname              String?
  lastname               String?
  role                   Role           @default(PATIENT)
  speciality             String?
  bio                    String?        @db.Text
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  patient                Patient?
  provider               Provider?
  appointmentsAsPatient  Appointment[]  @relation("PatientAppointments")
  appointmentsAsProvider Appointment[]  @relation("ProviderAppointments")
  healthData             HealthData[]
  fitbitToken            FitbitToken?
  auditTrails            AuditTrail[]   @relation("PerformedBy")
  notesAsPatient         ClinicalNote[] @relation("PatientNotes")
  notesAsProvider        ClinicalNote[] @relation("ProviderNotes")
  ClinicalNote           ClinicalNote[]
}

model Appointment {
  id         String            @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(SCHEDULED)
  reason     String?
  patient    User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId  String
  provider   User              @relation("ProviderAppointments", fields: [providerId], references: [id])
  providerId String

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ClinicalNote ClinicalNote?

  @@unique([patientId, startTime])
  @@unique([providerId, startTime])
}

model Patient {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id])
  wearableToken  String?
  medicalHistory MedicalHistory[]
  labResults     LabResult[]
  prescriptions  Prescription[]
}

model Provider {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model MedicalHistory {
  id        String       @id @default(cuid())
  patientId String
  details   String
  new       String?
  date      DateTime     @default(now())
  patient   Patient      @relation(fields: [patientId], references: [id])
  audits    AuditTrail[] @relation("MedicalHistoryAudit")
}

model LabResult {
  id        String       @id @default(cuid())
  patientId String
  type      String
  results   Json
  date      DateTime     @default(now())
  patient   Patient      @relation(fields: [patientId], references: [id])
  audits    AuditTrail[] @relation("LabResultAudit")
}

model Prescription {
  id         String       @id @default(cuid())
  patientId  String
  medication String
  dosage     String
  date       DateTime     @default(now())
  patient    Patient      @relation(fields: [patientId], references: [id])
  audits     AuditTrail[] @relation("PrescriptionAudit")
}

model HealthData {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  value     Json
  source    String? // e.g., "Fitbit", "Dexcom"
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FitbitToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  accessToken  String
  refreshToken String
  expiresAt    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditTrail {
  id               String          @id @default(cuid())
  action           String
  performedById    String
  performedBy      User            @relation("PerformedBy", fields: [performedById], references: [id])
  patientId        String
  timestamp        DateTime        @default(now())
  medicalHistoryId String?
  labResultId      String?
  prescriptionId   String?
  medicalHistory   MedicalHistory? @relation("MedicalHistoryAudit", fields: [medicalHistoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  labResult        LabResult?      @relation("LabResultAudit", fields: [labResultId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prescription     Prescription?   @relation("PrescriptionAudit", fields: [prescriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum Role {
  PATIENT
  PROVIDER
  ADMIN
}

